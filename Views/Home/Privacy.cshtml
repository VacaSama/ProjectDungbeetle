@{
    ViewData["Title"] = "Privacy Policy";
}

<body>
    <div class="container">
        <h1 style="text-align:center; margin-top: -5px;">Project Dungbeetle</h1>
        <div class="text-center">
        <img src="~/imgs/project_dungbeetle_sticker.png" alt="PDB_Logo" class="logo" style="max-width: 250px;" />
        </div>
        <p style="text-align:center; margin-top: -5px;">A tiny space for your big debugging moments.</p>

        <h2 class="mb-4">About</h2>
        <div class="card section">
            <div class="mb-4">
                Project Dungbeetle is a personal debugging journal designed to help you slow down, think clearly, and track your growth as a developer.
                It’s a quiet place to drop your errors, your breakthroughs, and the little lessons you pick up along the way.
            </div>

            <div>
                No pressure. No noise. Just you, your thoughts, and your progress — one entry at a time.
            </div>
        </div>

        <h2 class="mb-4">Privacy</h2>
        <div class="card section">
            <div class="mb-4">
                Your data stays on your device.
                Nothing is uploaded, shared, tracked, or sent anywhere.
            </div>

            <div class="mb-4">
                Entries, tags, reflections, and patterns are stored locally and belong entirely to you.
                Delete them anytime — they disappear completely.
            </div>

            <div>
                Project Dungbeetle doesn’t collect analytics, personal info, or usage data.
                It’s built to be private by default.
            </div>
        </div>

        <p class="small mb-3">Made with care for developers who just need a moment to breathe.</p>

    </div>
</body>

