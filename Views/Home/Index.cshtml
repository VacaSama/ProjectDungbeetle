@model ProjectDungbeetle.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}
<div>
<h1 style="text-align:center; margin-top: -5px;">Welcome to Project Dungbeetle!</h1>
<h2 style="text-align:center; margin-top: -5px;"> Your personal coding journal!</h2>
</div>
<!--MODAL FOR THE QUESTIONNAIRE - DO NOT REMOVE -->


<div id="questionnaireModal" class="questionnaireModal modal-overlay ">
    <div class="questionnaire-content modal-content">
        <h2 style="text-align:center">Let's start with a few questions! &#128515</h2>
        <hr />

        <form id="questionnaireForm">
            @if (Model.Questionnaire != null)
            {
                @foreach (var q in Model.Questionnaire)
                {
                    <div class="question-block mb-4">
                        <label class="fw-bold d-block mb-2">@q.QuestionText</label>

                        @{
                            // Split the string by commas.
                            // .Trim() removes extra spaces
                            var splitOptions = q.Options.Split(',').Select(s => s.Trim()).ToList();
                        }

                        @foreach (var opt in splitOptions)
                        {
                            <div class="form-check">
                                @if (q.IsMultiple)
                                {
                                    <input class="form-check-input" type="checkbox"
                                           name="q-@q.Id"
                                           value="@opt"
                                           id="opt-@q.Id-@opt">
                                }
                                else
                                {
                                    <input class="form-check-input" type="radio"
                                           name="q-@q.Id"
                                           value="@opt"
                                           id="opt-@q.Id-@opt">
                                }
                                <label class="form-check-label" for="opt-@q.Id-@opt">
                                    @opt
                                </label>
                            </div>
                        }
                    </div>
                }
            }
            <div class="modal-buttons">
                <button type="button" onclick="closeModal()" class="btn btn-outline-warning btn-skip mb-3">Skip for now</button>
                <button type="button" onclick="saveProfile()" class="btn btn-outline-success btn-save mb-3">Save & Finish</button>
            </div>
        </form>
    </div>
</div>

@* TOAST button for Randomized hint pop-ups, DO NOT REMOVE*@
<button id="liveToastBtn" class="btn btn-primary mb-3">Show Hint</button>

@*Here is the content and the position for the Toast, toast-body is left blank intentionally*@
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="toastHint" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header">
            <strong class="me-auto">Hint</strong>
            <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
        </div>
        <div id="hintText" class="toast-body"> <!--Random Hints go here, see dashboard.js--> </div>
    </div>
</div>


<!-- **** MODAL FOR ENTRY DO NOT REMOVE****-->
<button type="button" class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#newEntryModal" data-bs-whatever="">New Entry</button>

<div class="modal fade" id="newEntryModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h1 class="modal-title fs-5" id="newEntryLabel">New Entry</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Single form wrapping both modal-body and modal-footer -->
            <form asp-action="AddEntry" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="entry-title" class="col-form-label">*Entry Title:</label>
                        <input type="text" class="form-control" asp-for="Entry.Title" placeholder="Hello World!">
                    </div>

                    <div class="mb-3">
                        <label for="codinglanguage-type" class="col-form-label">*Coding Language</label>
                        <input type="text" class="form-control" asp-for="Entry.CodingLanguage" placeholder="C#">
                    </div>

                    <div class="mb-3">
                        <label for="code-snippet" class="col-form-label">*Code Snippet:</label>
                        <textarea class="form-control" asp-for="Entry.CodeSnippet" placeholder="<Code Here>"></textarea>
                    </div>

                    <div class="mb-3">
                        <label for="code-snippet" class="col-form-label">Error Description:</label>
                        <textarea class="form-control" asp-for="Entry.ErrorDescription" placeholder="Place Error Code/Error Type Here"></textarea>
                    </div>

                    <div class="mb-3">
                        <label for="notes-text" class="col-form-label">*Notes:</label>
                        <textarea class="form-control" asp-for="Entry.Notes" placeholder="Hello, I am a Note"></textarea>
                    </div>
                </div> <!-- closes modal-body -->

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add</button>
                </div>
            </form> <!-- closes form -->
        </div>
    </div>
</div>
 
@* so long as the entry is not null and has a value *@
@if(Model.Entries != null && Model.Entries.Any()) { 
    // for each entry print it as a card, with this content
    @foreach (var entry in Model.Entries){

        <div class="card border-light mb-3" style="max-width: 500px;">
            <div class="row g-0">

                <div class="col-md-8">
                    <div class="card-body">
                        <h5 class="card-title">@entry.Title</h5>
                        <p class="card-text">@entry.CodeSnippet</p>
                        <p class="card card-text">@entry.Notes</p>
                        <p class="card-text"><small class="text-body-secondary">Error Description: @entry.ErrorDescription</small></p>

                        <p class="card-text"><small class="text-body-secondary">Last Updated: @entry.CreatedAt</small></p>
                        
                        
                        <button type="button" class="btn btn-secondary btn-sm">Edit Entry</button>  <!-- edit button-->


                        <form asp-action="DeleteEntry" method="post" onsubmit="return confirm('Are you sure you want to delete: @entry.Title');" style="display:inline;">
                            <input type="hidden" name="entryId" value="@entry.Id" />
                            <button type="submit" class="btn btn-danger btn-sm">Delete Entry</button>  <!--delete button-->
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
}
else
{
    <p class="text-muted text-center">No entries found.</p>
}

<!-- Tabs -->
<ul class="nav nav-tabs" id="notesHintsTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="notes-tab" data-bs-toggle="tab" data-bs-target="#notes" type="button" role="tab">
            Notes
        </button>
    </li>

    <li class="nav-item" role="presentation">
        <button class="nav-link" id="hints-tab" data-bs-toggle="tab" data-bs-target="#hints" type="button" role="tab">
            Hints
        </button>
    </li>
</ul>



@*Serializing the Hints for JS to use and access, DO NOT REMOVE *@

@section Scripts { 
    <script>
        // Serializing the Hints for JS to use and access, DO NOT REMOVE
        // RANDOMIZED HINTS
        window.dashboardHints = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.Hints?.Select(h => h.HintText)));
    </script>

    <script>
    // QUESTIONNAIRE CHECK - if there are questions, show the modal, if not, skip it. DO NOT REMOVE'
    // QUESTIONNAIRE JAVASCRIPT LOGIC FROM dashboard.js previously was located in the site.js file.
        window.mustShowSurvey = @((Model.Questionnaire != null && Model.Questionnaire.Count > 0).ToString().ToLower());
    </script>

    <script src="~/js/dashboard.js"></script>
}


